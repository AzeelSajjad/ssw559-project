{
  "id": null,
  "uid": "devsecops-main",
  "title": "DevSecOps App — Operational Dashboard",
  "description": "SSW 559 Team Project — Real-time monitoring for devsecops-sample-app",
  "tags": ["devsecops", "node", "ssw559"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },

  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "query": "label_values(up, job)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "refresh": 2,
        "includeAll": false,
        "current": { "text": "devsecops-app", "value": "devsecops-app" }
      }
    ]
  },

  "panels": [
    {
      "id": 1,
      "title": "Application Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "up{job=\"devsecops-app\"}",
          "legendFormat": "Status"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Requests / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "round(sum(rate(http_requests_total{job=\"devsecops-app\"}[1m])) * 60)",
          "legendFormat": "req/min"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "reqpm"
        }
      }
    },
    {
      "id": 3,
      "title": "P95 Response Time",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"devsecops-app\"}[5m])) by (le))",
          "legendFormat": "P95 Latency"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"devsecops-app\", status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"devsecops-app\"}[5m])) * 100",
          "legendFormat": "Error Rate %"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "active_connections{job=\"devsecops-app\"}",
          "legendFormat": "Active"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "App Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=\"devsecops-app\"}",
          "legendFormat": "Uptime"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      }
    },

    {
      "id": 10,
      "title": "HTTP Requests Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{job=\"devsecops-app\"}[1m]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "placement": "bottom", "displayMode": "table" } }
    },
    {
      "id": 11,
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"devsecops-app\"}[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket{job=\"devsecops-app\"}[5m])) by (le))",
          "legendFormat": "P90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"devsecops-app\"}[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineInterpolation": "smooth" }
        }
      },
      "options": { "legend": { "placement": "bottom" } }
    },

    {
      "id": 20,
      "title": "Node.js Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"devsecops-app\"}",
          "legendFormat": "RSS (Resident)"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"devsecops-app\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"devsecops-app\"}",
          "legendFormat": "Heap Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "placement": "bottom", "displayMode": "table" } }
    },
    {
      "id": 21,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"devsecops-app\"}[1m]) * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },

    {
      "id": 30,
      "title": "HTTP Status Code Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status_code) (increase(http_requests_total{job=\"devsecops-app\"}[1h]))",
          "legendFormat": "{{status_code}}"
        }
      ],
      "options": { "pieType": "donut", "legend": { "placement": "right" } }
    },
    {
      "id": 31,
      "title": "Requests by Route (last 1h)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sort_desc(sum by (route) (increase(http_requests_total{job=\"devsecops-app\"}[1h])))",
          "legendFormat": "{{route}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "id": 32,
      "title": "Node.js Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"devsecops-app\"}",
          "legendFormat": "Event Loop Lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      }
    }
  ]
}
